PORT=5000
CLIENT_URL=http://localhost:3000

# Local MongoDB fallback for development.
MONGODB_URI=mongodb://127.0.0.1:27017/diamarket
# Or Atlas SRV (replace with the official URI from your Atlas cluster):
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/diamarket?retryWrites=true&w=majority

# Set to true only for UI development when MongoDB is temporarily unavailable.
# In degraded mode, /api/health works and DB-backed routes return 503.
ALLOW_API_WITHOUT_DB=true
# Diapay Checkout (sandbox)
DIAPAY_API_BASE_URL=http://localhost:5100
DIAPAY_SECRET_KEY=sk_test_xxx
DIAPAY_PUBLIC_KEY=pk_test_xxx
DIAPAY_WEBHOOK_SECRET=whsec_xxx
DIAMARKET_SUCCESS_URL=http://localhost:3000/orders/success
DIAMARKET_CANCEL_URL=http://localhost:3000/orders/cancel
