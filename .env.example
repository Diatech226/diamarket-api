NODE_ENV=development
PORT=5000

# MongoDB is required for readiness and DB-backed routes.
MONGODB_URI=mongodb://127.0.0.1:27017/diamarket
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-hostname>/diamarket?retryWrites=true&w=majority

# Authentication and session settings. Always replace secrets outside local development.
PUBLIC_REGISTRATION_ENABLED=true
ENABLE_EMAIL_PASSWORD_AUTH=true
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
AUTH_SESSION_TTL_HOURS=168
AUTH_ALLOW_HEADER_BRIDGE=false
CLERK_ISSUER_URL=
CLERK_SECRET_KEY=

# Comma-separated storefront and CMS origins. Required outside development.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional local admin bootstrap. Leave blank when unused.
ADMIN_DEFAULT_EMAIL=admin@diamarket.local
ADMIN_DEFAULT_PASSWORD=ChangeMe123!
ADMIN_DEFAULT_NAME=Diamarket Admin
ADMIN_WHITELIST=

# Diapay integration.
PAYMENT_PROVIDER=mock
PAYMENT_DEFAULT_CURRENCY=XOF
DIAPAY_API_BASE_URL=http://localhost:5100
DIAPAY_API_KEY=
DIAPAY_SECRET_KEY=
DIAPAY_PUBLIC_KEY=
DIAPAY_WEBHOOK_SECRET=
DIAPAY_WEBHOOK_TOLERANCE_SECONDS=300
DIAPAY_API_TIMEOUT=15000
DIAMARKET_SUCCESS_URL=http://localhost:3000/orders/success
DIAMARKET_CANCEL_URL=http://localhost:3000/orders/cancel

# Shipping integration. Use "mock" only for explicit local/demo testing.
SHIPPING_PROVIDER=diaexpress
SHIPPING_API_BASE_URL=
SHIPPING_API_KEY=
SHIPPING_API_TIMEOUT=15000
SHIPPING_DEFAULT_ORIGIN_COUNTRY=Burkina Faso
SHIPPING_DEFAULT_ORIGIN_CITY=Ouagadougou

# DiaExpress provider (mock fallback is allowed only when explicitly enabled).
DIAEXPRESS_API_BASE_URL=http://localhost:5200
DIAEXPRESS_API_KEY=
DIAEXPRESS_WEBHOOK_SECRET=
SHIPPING_DEMO_MODE=false
SHIPPING_DEFAULT_CURRENCY=XOF
